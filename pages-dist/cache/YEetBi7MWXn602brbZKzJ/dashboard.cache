ies\",\"style\":{\"color\":\"#fff\",\"fontSize\":\"14px\",\"textDecoration\":\"none\",\"fontWeight\":700},\"children\":\"All Movies\"}],[\"$\",\"$L4\",null,{\"href\":\"/dashboard\",\"style\":{\"color\":\"#fff\",\"fontSize\":\"14px\",\"textDecoration\":\"none\",\"fontWeight\":700},\"children\":\"Monetization\"}]]}]\nc:[\"$\",\"p\",null,{\"style\":{\"color\":\"var(--text-muted)\",\"fontSize\":\"12px\",\"fontWeight\":800,\"letterSpacing\":\"2px\"},\"children\":[\"© \",2026,\" WATCH THE FULL MOVIE ENTERTAINMENT. PARTNERED WITH ADSTERRA.\"]}]\nd:[\"$\",\"$L13\",null,{}]\ne:[\"$\",\"$1\",\"c\",{\"children\":[null,[\"$\",\"$L6\",null,{\"parallelRouterKey\":\"children\",\"error\":\"$undefined\",\"errorStyles\":\"$undefined\",\"errorScripts\":\"$undefined\",\"template\":[\"$\",\"$L7\",null,{}],\"templateStyles\":\"$undefined\",\"templateScripts\":\"$undefined\",\"notFound\":\"$undefined\",\"forbidden\":\"$undefined\",\"unauthorized\":\"$undefined\"}]]}]\nf:[\"$\",\"$1\",\"c\",{\"children\":[[\"$\",\"$L14\",null,{\"initialMovies\":[{\"id\":1,\"title\":\"The Aviator\",\"poster_path\":\"https://img.youtube.com/vi/fFPHaHmt8I0/maxresdefault.jpg\",\"backdrop_path\":\"https://img.youtube.com/vi/fFPHaHmt8I0/maxresdefault.jpg\",\"release_date\":\"2026-05-01\",\"vote_average\":9.2,\"overview\":\"The Avengers assemble once again to face a threat unlike any they have ever encountered: Victor Von Doom.\",\"genre_ids\":[28,12,878],\"trailer_id\":\"fFPHaHmt8I0\",\"quality\":\"UHD 4K\",\"duration\":\"162m\",\"review_content\":\"A high-intensity cinematic event with premium visuals, sharp pacing, and blockbuster-scale action from start to finish.\"},{\"id\":32,\"title\":\"20th Century Fox\",\"poster_path\":\"https://img.youtube.com/vi/y0caojFEPBs/maxresdefault.jpg\",\"backdrop_path\":\"https://img.youtube.com/vi/y0caojFEPBs/maxresdefault.jpg\",\"release_date\":\"2024-01-01\",\"vote_average\":9.5,\"overview\":\"The iconic 20th Century Fox cinematic intro in stunning 4K high-fidelity resolution.\",\"genre_ids\":[28,12,878],\"trailer_id\":\"y0caojFEPBs\",\"quality\":\"UHD 4K\",\"duration\":\"30s\",\"review_content\":\"A masterpiece of cinematic history that defined generations of movie-going experiences.\"},{\"id\":2,\"title\":\"Avengers: Doomsday\",\"poster_path\":\"https://img.youtube.com/vi/bKjaQWOM3fo/maxresdefault.jpg\",\"backdrop_path\":\"https://img.youtube.com/vi/bKjaQWOM3fo/maxresdefault.jpg\",\"release_date\":\"2026-05-01\",\"vote_average\":9.2,\"overview\":\"The Avengers assemble once again to face a threat unlike any they have ever encountered: Victor Von Doom.\",\"genre_ids\":[28,12,878],\"trailer_id\":\"bKjaQWOM3fo\",\"quality\":\"UHD 4K\",\"duration\":\"154m\",\"review_content\":\"Robert Downey Jr.'s return as Dr. Doom is the cinematic event of the decade. The stakes have never been higher as the Multiverse hangs in the balance. A masterful blend of high-octane action and deep character drama.\"},{\"id\":3,\"title\":\"The Batman Part II\",\"poster_path\":\"https://img.youtube.com/vi/wY8XcmrIujE/maxresdefault.jpg\",\"backdrop_path\":\"https://img.youtube.com/vi/wY8XcmrIujE/maxresdefault.jpg\",\"release_date\":\"2026-10-02\",\"vote_average\":8.5,\"overview\":\"Robert Pattinson returns as the Dark Knight in a Gotham City still reeling from the events of the first film.\",\"genre_ids\":[18,80],\"trailer_id\":\"wY8XcmrIujE\",\"quality\":\"UHD 4K\",\"duration\":\"148m\",\"review_content\":\"Matt Reeves continues his grounded, noir-inspired take on the Caped Crusader. This sequel dives deeper into the corruption of Gotham, introducing new villains that challenge Batman's detective skills and mental fortitude.\"},{\"id\":4,\"title\":\"The Super Mario Bros. Movie 2\",\"poster_path\":\"https://img.youtube.com/vi/OQEZHXYG8r4/maxresdefault.jpg\",\"backdrop_path\":\"https://img.youtube.com/vi/OQEZHXYG8r4/maxresdefault.jpg\",\"release_date\":\"2026-04-03\",\"vote_average\":7.9,\"overview\":\"No overview available.\",\"genre_ids\":[16,12,35],\"trailer_id\":\"OQEZHXYG8r4\",\"quality\":\"UHD 4K\",\"duration\":\"105m\",\"review_content\":\"Illumination and Nintendo deliver another vibrant, fun-filled romp. With new power-ups and beloved characters making their debut, this sequel is a treat for fans of all ages.\"},{\"id\":5,\"title\":\"Spider-Man: Beyond the Spider-Verse\",\"poster_path\":\"https://img.youtube.com/vi/Wy1pIFF5imc/maxresdefault.jpg\",\"backdrop_path\":\"https://img.youtube.com/vi/Wy1pIFF5imc/maxresdefault.jpg\",\"release_date\":\"2026-03-27\",\"vote_average\":8,\"overview\":\"No overview available.\",\"genre_ids\":[16,28,12,878],\"trailer_id\":\"Wy1pIFF5imc\",\"quality\":\"HD\",\"duration\":\"120m\",\"review_content\":\"The trilogy concludes with a visually stunning and emotionally resonant masterpiece. The animation styles blend seamlessly as Miles faces his toughest challenge yet.\"},{\"id\":6,\"title\":\"Jurassic World: Rebirth\",\"poster_path\":\"https://img.youtube.com/vi/7jI_6c8xRzo/maxresdefault.jpg\",\"backdrop_path\":\"https://img.youtube.com/vi/7jI_6c8xRzo/maxresdefault.jpg\",\"release_date\":\"2025-07-02\",\"vote_average\":7.5,\"overview\":\"A new era of dinosaurs begins as humanity struggles to coexist with the prehistoric giants.\",\"genre_ids\":[28,12,878],\"trailer_id\":\"7jI_6c8xRzo\",\"quality\":\"UHD 4K\",\"duration\":\"125m\",\"review_content\":\"A fresh start for the franchise that returns to the wonder and terror of the original films. Scarlett Johansson leads a stellar cast in a survival thriller that doesn't hold back.\"},{\"id\":7,\"title\":\"The Mandalorian & Grogu\",\"poster_path\":\"https://img.youtube.com/vi/t8f_Wp2S1_o/maxresdefault.jpg\",\"backdrop_path\":\"https://img.youtube.com/vi/t8f_Wp2S1_o/maxresdefault.jpg\",\"release_date\":\"2026-05-22\",\"vote_average\":8.4,\"overview\":\"Din Djarin and Grogu take their adventures to the big screen.\",\"genre_ids\":[28,12,878],\"trailer_id\":\"t8f_Wp2S1_o\",\"quality\":\"UHD 4K\",\"duration\":\"118m\",\"review_content\":\"The beloved duo makes a grand leap to cinemas. The scale is epic, but the heart of the story remains the bond between a hunter and his foundling. A must-watch for Star Wars fans.\"},{\"id\":8,\"title\":\"Toy Story 5\",\"poster_path\":\"https://img.youtube.com/vi/X_zQo-QhA0Y/maxresdefault.jpg\",\"backdrop_path\":\"https://img.youtube.com/vi/X_zQo-QhA0Y/maxresdefault.jpg\",\"release_date\":\"2026-06-19\",\"vote_average\":7.8,\"overview\":\"Woody, Buzz, and the gang reunite for a new chapter in their lives.\",\"genre_ids\":[16,12,35,10751],\"trailer_id\":\"X_zQo-QhA0Y\",\"quality\":\"UHD 4K\",\"duration\":\"100m\",\"review_content\":\"Pixar somehow finds new emotional ground to cover with these iconic characters. A poignant reflection on friendship and the passage of time, wrapped in a fun adventure.\"},{\"id\":9,\"title\":\"Supergirl: Woman of Tomorrow\",\"poster_path\":\"https://img.youtube.com/vi/EGo6rXjA_zY/maxresdefault.jpg\",\"backdrop_path\":\"https://img.youtube.com/vi/EGo6rXjA_zY/maxresdefault.jpg\",\"release_date\":\"2026-06-26\",\"vote_average\":8.1,\"overview\":\"Kara Zor-El travels the galaxy to find her own identity and become a hero.\",\"genre_ids\":[28,12,878],\"trailer_id\":\"EGo6rXjA_zY\",\"quality\":\"UHD 4K\",\"duration\":\"130m\",\"review_content\":\"Grounded in a space-epic aesthetic, this film introduces a Supergirl that is both powerful and vulnerable. A standout entry in the new DCU.\"},{\"id\":10,\"title\":\"Masters of the Universe\",\"poster_path\":\"https://img.youtube.com/vi/5qV8XvR9y_o/maxresdefault.jpg\",\"backdrop_path\":\"https://img.youtube.com/vi/5qV8XvR9y_o/maxresdefault.jpg\",\"release_date\":\"2026-06-05\",\"vote_average\":7.6,\"overview\":\"He-Man must defend Eternia from the evil forces of Skeletor.\",\"genre_ids\":[28,12,14],\"trailer_id\":\"5qV8XvR9y_o\",\"quality\":\"UHD 4K\",\"duration\":\"122m\",\"review_content\":\"A high-fantasy epic that finally gives He-Man the big-screen treatment he deserves. The production design is spectacular, bringing Eternia to life in vivid detail.\"},{\"id\":11,\"title\":\"Moana 2\",\"poster_path\":\"https://img.youtube.com/vi/hXz3m6Z2Z_o/maxresdefault.jpg\",\"backdrop_path\":\"https://img.youtube.com/vi/hXz3m6Z2Z_o/maxresdefault.jpg\",\"release_date\":\"2024-11-27\",\"vote_average\":8,\"overview\":\"Moana sets sail on a new voyage to the far seas of Oceania.\",\"genre_ids\":[16,12,35,10751],\"trailer_id\":\"hXz3m6Z2Z_o\",\"quality\":\"UHD 4K\",\"duration\":\"108m\",\"review_content\":\"Disney delivers another magical musical adventure. The chemistry between Moana and Maui remains the highlight, set against breathtaking oceanic vistas.\"},{\"id\":12,\"title\":\"Mufasa: The Lion King\",\"poster_path\":\"https://img.youtube.com/vi/o17MF9WkSRE/maxresdefault.jpg\",\"backdrop_path\":\"https://img.youtube.com/vi/o17MF9WkSRE/maxresdefault.jpg\",\"release_date\":\"2024-12-20\",\"vote_average\":7.4,\"overview\":\"The origin story of the legendary Pride Rock king.\",\"genre_ids\":[28,12,18,10751],\"trailer_id\":\"o17MF9WkSRE\",\"quality\":\"UHD 4K\",\"duration\":\"115m\",\"review_content\":\"Barry Jenkins brings his poetic touch to the Pride Lands. This prequel offers a nuanced look at the rise of Mufasa and his relationship with Taka (Scar).\"},{\"id\":13,\"title\":\"Sonic the Hedgehog 3\",\"poster_path\":\"https://img.youtube.com/vi/qSu6i2iFKN0/maxresdefault.jpg\",\"backdrop_path\":\"https://img.youtube.com/vi/qSu6i2iFKN0/maxresdefault.jpg\",\"release_date\":\"2024-12-20\",\"vote_average\":8.2,\"overview\":\"Sonic, Tails, and Knuckles face off against a new threat: Shadow.\",\"genre_ids\":[28,12,35,10751],\"trailer_id\":\"qSu6i2iFKN0\",\"quality\":\"UHD 4K\",\"duration\":\"110m\",\"review_content\":\"The franchise continues its winning streak with the introduction of Shadow. The action is faster, and the stakes are higher than ever before.\"},{\"id\":14,\"title\":\"Gladiator II\",\"poster_path\":\"https://img.youtube.com/vi/4L6p-8Qv68k/maxresdefault.jpg\",\"backdrop_path\":\"https://img.youtube.com/vi/4L6p-8Qv68k/maxresdefault.jpg\",\"release_date\":\"2024-11-22\",\"vote_average\":7.7,\"overview\":\"Years after the death of Maximus, Lucius enters the Colosseum.\",\"genre_ids\":[28,12,18],\"trailer_id\":\"4L6p-8Qv68k\",\"quality\":\"UHD 4K\",\"duration\":\"148m\",\"review_content\":\"Ridley Scott returns to the arena with an epic scope. Paul Mescal is riveting as Lucius, capturing the legacy of the first film while carving his own path.\"},{\"id\":15,\"title\":\"Wicked\",\"poster_path\":\"https://img.youtube.com/vi/6COmYeLsz4c/maxresdefault.jpg\",\"backdrop_path\":\"https://img.youtube.com/vi/6COmYeLsz4c/maxresdefault.jpg\",\"release_date\":\"2024-11-22\",\"vote_average\":8.5,\"overview\":\"The untold story of the witches of Oz.\",\"genre_ids\":[14,10402,10749],\"trailer_id\":\"6COmYeLsz4c\",\"quality\":\"UHD 4K\",\"duration\":\"160m\",\"review_content\":\"Cynthia Erivo and Ariana Grande are spectacular in this faithful and grand adaptation. A visual feast that honors the beloved stage musical.\"},{\"id\":16,\"title\":\"Paddington in Peru\",\"poster_path\":\"https://img.youtube.com/vi/L6P3nI6V_Is/maxresdefault.jpg\",\"backdrop_path\":\"https://img.youtube.com/vi/L6P3nI6V_Is/maxresdefault.jpg\",\"release_date\":\"2024-11-08\",\"vote_average\":8,\"overview\":\"Paddington travels to Peru to visit his Aunt Lucy.\",\"genre_ids\":[12,35,10751],\"trailer_id\":\"L6P3nI6V_Is\",\"quality\":\"UHD 4K\",\"duration\":\"103m\",\"review_content\":\"Our favorite bear returns in another heartwarming and hilarious adventure. The shift to the Amazon brings a fresh energy and wonderful new characters.\"},{\"id\":17,\"title\":\"Red One\",\"poster_path\":\"https://img.youtube.com/vi/wL7vMId5Y5I/maxresdefault.jpg\",\"backdrop_path\":\"https://img.youtube.com/vi/wL7vMId5Y5I/maxresdefault.jpg\",\"release_date\":\"2024-11-15\",\"vote_average\":6.8,\"overview\":\"A polar bounty hunter must rescue Santa Claus.\",\"genre_ids\":[28,12,35,14],\"trailer_id\":\"wL7vMId5Y5I\",\"quality\":\"UHD 4K\",\"duration\":\"123m\",\"review_content\":\"A high-octane holiday adventure that blends action and mythology. The Rock and Chris Evans have great chemistry in this unique Christmas caper.\"},{\"id\":18,\"title\":\"Elevation\",\"poster_path\":\"https://img.youtube.com/vi/XgJcRmsT1C0/maxresdefault.jpg\",\"backdrop_path\":\"https://img.youtube.com/vi/XgJcRmsT1C0/maxresdefault.jpg\",\"release_date\":\"2024-11-08\",\"vote_average\":7.1,\"overview\":\"A single father and two women venture from safety to face monstrous creatures to save a young boy's life.\",\"genre_ids\":[28,878,53],\"trailer_id\":\"XgJcRmsT1C0\",\"quality\":\"UHD 4K\",\"duration\":\"100m\",\"review_content\":\"A tense, post-apocalyptic thriller with a strong core of survival. Anthony Mackie delivers a grounded performance in a world filled with danger.\"},{\"id\":19,\"title\":\"Nosferatu\",\"poster_path\":\"https://img.youtube.com/vi/nur0rOPr6QA/maxresdefault.jpg\",\"backdrop_path\":\"https://img.youtube.com/vi/nur0rOPr6QA/maxresdefault.jpg\",\"release_date\":\"2024-12-25\",\"vote_average\":8.7,\"overview\":\"A gothic tale of obsession between a haunted young woman and the terrifying vampire infatuated with her.\",\"genre_ids\":[14,27],\"trailer_id\":\"nur0rOPr6QA\",\"quality\":\"UHD 4K\",\"duration\":\"135m\",\"review_content\":\"Robert Eggers creates a chillingly beautiful masterwork. Bill Skarsgård's portrayal of Count Orlok is haunting, and the atmosphere is thick with dread. A horror classic in the making.\"},{\"id\":20,\"title\":\"Better Man\",\"poster_path\":\"https://img.youtube.com/vi/K0tA8W5m-hY/maxresdefault.jpg\",\"backdrop_path\":\"https://img.youtube.com/vi/K0tA8W5m-hY/maxresdefault.jpg\",\"release_date\":\"2024-12-25\",\"vote_average\":7.5,\"overview\":\"The life of Robbie Williams, as told from his perspective.\",\"genre_ids\":[18,10402],\"trailer_id\":\"K0tA8W5m-hY\",\"quality\":\"UHD 4K\",\"duration\":\"135m\",\"review_content\":\"A unique and creative musical biopic that isn't afraid to take risks. A visually inventive celebration of one of pop music's biggest stars.\"},{\"id\":21,\"title\":\"A Complete Unknown\",\"poster_path\":\"https://img.youtube.com/vi/fBcl7Niz058/maxresdefault.jpg\",\"backdrop_path\":\"https://img.youtube.com/vi/fBcl7Niz058/maxresdefault.jpg\",\"release_date\":\"2024-12-25\",\"vote_average\":8.3,\"overview\":\"At the Newport Folk Festival in 1965, Bob Dylan shakes up the music world.\",\"genre_ids\":[18,10402],\"trailer_id\":\"fBcl7Niz058\",\"quality\":\"UHD 4K\",\"duration\":\"140m\",\"review_content\":\"Timothée Chalamet disappears into the role of young Bob Dylan. A poignant look at a pivotal moment in music history, expertly directed by James Mangold.\"},{\"id\":22,\"title\":\"The Brutalist\",\"poster_path\":\"https://img.youtube.com/vi/J_D8zYQoR_Y/maxresdefault.jpg\",\"backdrop_path\":\"https://img.youtube.com/vi/J_D8zYQoR_Y/maxresdefault.jpg\",\"release_date\":\"2024-12-20\",\"vote_average\":8.9,\"overview\":\"A Hungarian-born Jewish architect who survives the Holocaust and migrates to the US.\",\"genre_ids\":[18],\"trailer_id\":\"J_D8zYQoR_Y\",\"quality\":\"70mm Film\",\"duration\":\"215m\",\"review_content\":\"An overwhelming cinematic achievement. A sprawling, epic drama about legacy, memory, and the American dream. Adrien Brody gives a career-best performance.\"},{\"id\":23,\"title\":\"Flow\",\"poster_path\":\"https://img.youtube.com/vi/s0A_vO8YV4o/maxresdefault.jpg\",\"backdrop_path\":\"https://img.youtube.com/vi/s0A_vO8YV4o/maxresdefault.jpg\",\"release_date\":\"2024-11-22\",\"vote_average\":8.1,\"overview\":\"A cat wakes up in a world covered in water.\",\"genre_ids\":[16,12,14],\"trailer_id\":\"s0A_vO8YV4o\",\"quality\":\"UHD 4K\",\"duration\":\"84m\",\"review_content\":\"A silent, visual masterpiece that proves you don't need dialogue to tell a powerful story. The animation is unique and evocative, capturing a world in transition.\"},{\"id\":24,\"title\":\"September 5\",\"poster_path\":\"https://img.youtube.com/vi/p8uX51p92-s/maxresdefault.jpg\",\"backdrop_path\":\"https://img.youtube.com/vi/p8uX51p92-s/maxresdefault.jpg\",\"release_date\":\"2024-11-27\",\"vote_average\":7.9,\"overview\":\"A sports broadcasting team during the 1972 Munich Olympics.\",\"genre_ids\":[18,53,36],\"trailer_id\":\"p8uX51p92-s\",\"quality\":\"UHD 4K\",\"duration\":\"91m\",\"review_content\":\"A high-stakes journalistic thriller that explores the ethical dilemmas of news broadcasting. A taut, gripping look at a world-changing event.\"},{\"id\":25,\"title\":\"Smile 2\",\"poster_path\":\"https://img.youtube.com/vi/_it_n8X0C5A/maxresdefault.jpg\",\"backdrop_path\":\"https://img.youtube.com/vi/_it_n8X0C5A/maxresdefault.jpg\",\"release_date\":\"2024-10-18\",\"vote_average\":7.2,\"overview\":\"A pop star begins experiencing terrifying events.\",\"genre_ids\":[27,53],\"trailer_id\":\"_it_n8X0C5A\",\"quality\":\"UHD 4K\",\"duration\":\"127m\",\"review_content\":\"A sequel that raises the stakes and the scares. Naomi Scott is impressive as the haunted diva in this psychological horror romp.\"},{\"id\":26,\"title\":\"Terrifier 3\",\"poster_path\":\"https://img.youtube.com/vi/L06_NfU0X-E/maxresdefault.jpg\",\"backdrop_path\":\"https://img.youtube.com/vi/L06_NfU0X-E/maxresdefault.jpg\",\"release_date\":\"2024-10-11\",\"vote_average\":7,\"overview\":\"Art the Clown unleashes chaos at Christmas.\",\"genre_ids\":[27],\"trailer_id\":\"L06_NfU0X-E\",\"quality\":\"UHD 4K\",\"duration\":\"125m\",\"review_content\":\"Maximum carnage and practical effects brilliance. Art the Clown returns as a holiday nightmare in this unflinching horror spectacle.\"},{\"id\":27,\"title\":\"Heretic\",\"poster_path\":\"https://img.youtube.com/vi/0Z_fN5J5kC8/maxresdefault.jpg\",\"backdrop_path\":\"https://img.youtube.com/vi/0Z_fN5J5kC8/maxresdefault.jpg\",\"release_date\":\"2024-11-08\",\"vote_average\":7.8,\"overview\":\"Two young missionaries are forced to prove their faith when they knock on the wrong door.\",\"genre_ids\":[27,53],\"trailer_id\":\"0Z_fN5J5kC8\",\"quality\":\"UHD 4K\",\"duration\":\"111m\",\"review_content\":\"Hugh Grant is chilling in a psychological thriller that challenges beliefs. A smart, tense, and expertly crafted chamber piece from A24.\"},{\"id\":28,\"title\":\"Kraven the Hunter\",\"poster_path\":\"https://img.youtube.com/vi/Ywz6-A_mR3Q/maxresdefault.jpg\",\"backdrop_path\":\"https://img.youtube.com/vi/Ywz6-A_mR3Q/maxresdefault.jpg\",\"release_date\":\"2024-12-13\",\"vote_average\":6.7,\"overview\":\"The origin story of Marvel's most iconic hunter.\",\"genre_ids\":[28,12,53],\"trailer_id\":\"Ywz6-A_mR3Q\",\"quality\":\"UHD 4K\",\"duration\":\"124m\",\"review_content\":\"An R-rated action spectacle that doesn't hold back on the brutality. Aaron Taylor-Johnson brings an animalistic intensity to the lead role.\"},{\"id\":29,\"title\":\"Ballerina\",\"poster_path\":\"https://img.youtube.com/vi/7jI_6c8xRzo/maxresdefault.jpg\",\"backdrop_path\":\"https://img.youtube.com/vi/7jI_6c8xRzo/maxresdefault.jpg\",\"release_date\":\"2025-06-06\",\"vote_average\":8,\"overview\":\"A young woman seeks revenge against the people who killed her family.\",\"genre_ids\":[28,53],\"trailer_id\":\"7jI_6c8xRzo\",\"quality\":\"UHD 4K\",\"duration\":\"120m\",\"review_content\":\"Ana de Armas shines in this high-octane spin-off from the John Wick universe. The action sequences are choreographed with the same precision and style as the main franchise.\"},{\"id\":30,\"title\":\"Minecraft\",\"poster_path\":\"https://img.youtube.com/vi/mI60aZ_oU8s/maxresdefault.jpg\",\"backdrop_path\":\"https://img.youtube.com/vi/mI60aZ_oU8s/maxresdefault.jpg\",\"release_date\":\"2025-04-04\",\"vote_average\":7.2,\"overview\":\"The malevolent Ender Dragon sets out on a path of destruction.\",\"genre_ids\":[10751,12,35,14],\"trailer_id\":\"mI60aZ_oU8s\",\"quality\":\"UHD 4K\",\"duration\":\"112m\",\"review_content\":\"A visually unique adaptation that captures the imagination of the game. Jack Black and Jason Momoa bring a lot of energy to this blocky world.\"},{\"id\":31,\"title\":\"Spider-Man: Beyond the Spider-Verse\",\"poster_path\":\"https://img.youtube.com/vi/Wy1pIFF5imc/maxresdefault.jpg\",\"backdrop_path\":\"https://img.youtube.com/vi/Wy1pIFF5imc/maxresdefault.jpg\",\"release_date\":\"2000-12-23\",\"vote_average\":8,\"overview\":\"No overview available.\",\"genre_ids\":[28],\"trailer_id\":\"Wy1pIFF5imc\",\"review_content\":\"Editorial breakdown pending.\",\"quality\":\"HD\",\"duration\":\"120m\"}],\"initialSettings\":{\"adsterra\":\"$0:f:0:1:0:props:children:1:props:children:props:children:props:settings:adsterra\",\"site\":\"$0:f:0:1:0:props:children:1:props:children:props:children:props:settings:site\"}}],null,\"$L15\"]}]\n16:[]\n10:\"$W16\"\n11:[\"$\",\"$1\",\"h\",{\"children\":[null,[\"$\",\"$L17\",null,{\"children\":\"$L18\"}],[\"$\",\"div\",null,{\"hidden\":true,\"children\":[\"$\",\"$L19\",null,{\"children\":[\"$\",\"$1a\",null,{\"name\":\"Next.Metadata\",\"children\":\"$L1b\"}]}]}],null]}]\n1c:I[484,[],\"OutletBoundary\"]\n15:[\"$\",\"$L1c\",null,{\"children\":[\"$\",\"$1a\",null,{\"name\":\"Next.MetadataOutlet\",\"children\":\"$@1d\"}]}]\n18:[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}]]\n1b:[[\"$\",\"title\",\"0\",{\"children\":\"Dashboard | Manage Movies 2026\"}],[\"$\",\"meta\",\"1\",{\"name\":\"description\",\"content\":\"Secure admin dashboard for managing movie trailers and review articles.\"}],[\"$\",\"link\",\"2\",{\"rel\":\"canonical\",\"href\":\"https://adweb-movies.pages.dev\"}],[\"$\",\"meta\",\"3\",{\"property\":\"og:title\",\"content\":\"Watch The full movie 4k live and download\"}],[\"$\",\"meta\",\"4\",{\"property\":\"og:description\",\"content\":\"Premium Movie Trailer Portal\"}],[\"$\",\"meta\",\"5\",{\"property\":\"og:url\",\"content\":\"https://adweb-movies.pages.dev\"}],[\"$\",\"meta\",\"6\",{\"property\":\"og:sit